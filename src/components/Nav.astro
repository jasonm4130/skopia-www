---
import SkopiaMark from './SkopiaMark.astro';
---

<!-- ===== NAV ===== -->
<div class="nav-bar" style="position:sticky;top:0;z-index:50;background:rgba(10,12,17,.78);backdrop-filter:blur(14px);border-bottom:1px solid #161a22;">
  <div class="nav-inner" style="max-width:1180px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:18px 32px;">
    <a href="/" style="display:flex;align-items:center;gap:11px;">
      <SkopiaMark size="lg" />
      <span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:19px;letter-spacing:-.01em;color:#fff;">Skopia</span>
    </a>
    <div class="nav-cluster" style="display:flex;align-items:center;gap:30px;">
      <div id="nav-menu" class="nav-links" style="display:flex;align-items:center;gap:30px;font-size:14px;color:#9097a8;">
        <a href="#features" style="cursor:pointer;">Features</a>
        <a href="#how" style="cursor:pointer;">How it works</a>
        <a href="#pricing" style="cursor:pointer;">Pricing</a>
        <a href="#faq" style="cursor:pointer;">FAQ</a>
        <a href="https://github.com/jasonm4130/skopia" style="display:flex;align-items:center;gap:7px;border:1px solid #262b38;padding:8px 13px;border-radius:8px;color:#cfd4e0;"><span style="color:#ffce4d;">&#9733;</span> GitHub</a>
      </div>
      <button class="nav-burger" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu" style="display:none;flex-direction:column;justify-content:center;gap:5px;width:42px;height:42px;padding:0 9px;background:transparent;border:1px solid #262b38;border-radius:8px;cursor:pointer;">
        <span style="display:block;width:100%;height:2px;background:#cfd4e0;border-radius:2px;"></span>
        <span style="display:block;width:100%;height:2px;background:#cfd4e0;border-radius:2px;"></span>
        <span style="display:block;width:100%;height:2px;background:#cfd4e0;border-radius:2px;"></span>
      </button>
      <a href="https://app.skopia.dev/login" style="background:#4d86ff;color:#fff;padding:10px 18px;border-radius:8px;font-weight:600;font-size:13.5px;cursor:pointer;">Deploy free</a>
    </div>
  </div>
</div>

<style>
  /* Mobile only — desktop (>=769px) inherits the inline styles untouched. */
  @media (max-width: 768px) {
    .nav-inner { padding: 16px 20px !important; }
    .nav-cluster { gap: 14px !important; }
    .nav-burger { display: flex !important; }
    /* The 5 links + GitHub collapse into a dropdown toggled by the hamburger.
       Positioned against .nav-bar (position:sticky), so it drops full-width below the bar. */
    .nav-links {
      display: none !important;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start !important;
      gap: 20px !important;
      padding: 20px !important;
      background: #0a0c11;
      border-bottom: 1px solid #161a22;
      box-shadow: 0 24px 40px -24px rgba(0, 0, 0, .8);
    }
    .nav-links.open { display: flex !important; }
  }
</style>
