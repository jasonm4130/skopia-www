# Cloudflare Workers Static Assets honors this file for static asset responses.
# CSP is set HERE (not via Astro's security.csp): the page uses inline style=""
# attributes, which style hashes can't cover, so style-src needs 'unsafe-inline'.
# Script execution stays strict — script-src 'self', no inline JS (calculator.js is
# an external same-origin file).
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://app.skopia.dev; style-src 'self' 'unsafe-inline'; img-src 'self'; font-src 'self'; connect-src 'self' https://app.skopia.dev; frame-ancestors 'none'; base-uri 'none'; form-action 'self'; upgrade-insecure-requests

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/tokens.css
  Cache-Control: public, max-age=86400

/fonts.css
  Cache-Control: public, max-age=86400

/scripts/*
  Cache-Control: public, max-age=86400
